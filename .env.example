# OAuth app: WHOOP Developer Dashboard — values must match registration exactly.
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
# Callback URI with explicit host and port (required for local login). Example:
WHOOP_REDIRECT_URI=http://127.0.0.1:8780/callback

# Optional overrides (defaults match WHOOP documentation)
# WHOOP_AUTHORIZATION_URL=https://api.prod.whoop.com/oauth/oauth2/auth
# WHOOP_TOKEN_URL=https://api.prod.whoop.com/oauth/oauth2/token
# WHOOP_API_BASE_URL=https://api.prod.whoop.com/developer

# Space-separated scopes; include `offline` for refresh tokens
WHOOP_DEFAULT_SCOPES=offline read:profile read:cycles read:sleep read:recovery read:workout read:body_measurement

# HTTP client timeout for OAuth/API calls (seconds; 1–120)
# WHOOP_HTTP_TIMEOUT_SECONDS=30

# Refresh access tokens this many seconds before expiry (0–600; default 60)
# WHOOP_TOKEN_REFRESH_SKEW_SECONDS=60

# Token JSON path (default: ~/.config/whoop-mcp/tokens.json)
# WHOOP_TOKEN_STORE_PATH=

WHOOP_LOG_LEVEL=INFO
